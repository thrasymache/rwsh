image: alpine/latest
packages:
  - readline-dev
sources:
  - https://git.sr.ht/~thrasymache/rwsh
tasks:
  - build: |
        cd rwsh
        c++ --version
        # c++ (Alpine 8.3.0) 8.3.0 (FSF)
        make
  - install: |
        cd rwsh
        sudo make install
  - rwshrc-basic-devnull: |
        cd rwsh
        make rwshrc-basic-devnull
  - test: |
        cd rwsh
        make test
